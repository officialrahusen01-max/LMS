# Server Configuration (use 5000 for local dev; 443 on Windows needs Admin / may ECONNREFUSED from Next proxy)
PORT=5000
NODE_ENV=development

# Rate limits (optional). If NODE_ENV=production, default is 100 req / 15m (API) and 5 (auth).
# API_RATE_LIMIT_MAX=5000
# AUTH_RATE_LIMIT_MAX=100

# Database
# Option 1: MongoDB Atlas (whitelist your IP first)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/api_ai_com

# Option 2: Local MongoDB (uncomment this line and comment above)
# MONGODB_URI=mongodb://localhost:27017/api_ai_com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-here
REFRESH_TOKEN_EXPIRES_IN=30d

# Email Configuration (required for admin OTP login: POST /api/v1/auth/admin/request-otp)
#
# Gmail default in code: smtp.gmail.com port 587 (STARTTLS). EMAIL_USER + EMAIL_PASS (app password).
#
# "Self-signed certificate in certificate chain" (proxy / antivirus):
#   SMTP_TLS_REJECT_UNAUTHORIZED=false
#   (weakens TLS checks — dev/office only; remove in strict production)
#
# Optional explicit SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_FROM=no-reply@yourdomain.com
#
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Role Configuration
SUPERADMIN=superadmin
MANAGER=manager
ADMIN=admin
USER=user

# Cloudinary (required for POST /api/v1/upload/* — profile photo, course media)
# Dashboard: https://console.cloudinary.com/settings/api
CLOUDINARY_CLOUD_NAME=dlo0yff8v
CLOUDINARY_API_KEY=125141356795524
CLOUDINARY_API_SECRET=k0PPGXm8j5BcyrwSJMZbgUOmVrs

# OpenAI Configuration (for AI features)
OPENAI_API_KEY=your-openai-api-key-here
